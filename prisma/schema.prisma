generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ContentType {
  MOVIE
  SERIES
  ANIME
  CARTOON
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  avatar    String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  favorites    Favorite[]
  reviews      Review[]
  watchHistory WatchHistory[]
  subscription Subscription?
}

model Content {
  id          String      @id @default(cuid())
  title       String
  description String
  poster      String?
  backdrop    String?
  trailerUrl  String?
  videoUrl    String?
  type        ContentType
  year        Int
  duration    Int?
  country     String?
  rating      Float       @default(0)
  reviewCount Int         @default(0)
  views       Int         @default(0)
  createdAt   DateTime    @default(now())

  genres       ContentGenre[]
  actors       ContentActor[]
  seasons      Season[]
  favorites    Favorite[]
  reviews      Review[]
  watchHistory WatchHistory[]
}

model Genre {
  id       String         @id @default(cuid())
  name     String         @unique
  contents ContentGenre[]
}

model ContentGenre {
  contentId String
  genreId   String
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  genre     Genre   @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([contentId, genreId])
}

model Actor {
  id       String         @id @default(cuid())
  name     String
  photo    String?
  contents ContentActor[]
}

model ContentActor {
  contentId String
  actorId   String
  role      String?
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  actor     Actor   @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@id([contentId, actorId])
}

model Season {
  id        String    @id @default(cuid())
  contentId String
  number    Int
  title     String?
  content   Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episodes  Episode[]

  @@unique([contentId, number])
}

model Episode {
  id           String         @id @default(cuid())
  seasonId     String
  number       Int
  title        String
  videoUrl     String
  duration     Int?
  season       Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  watchHistory WatchHistory[]

  @@unique([seasonId, number])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  text      String
  rating    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model WatchHistory {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  episodeId String?
  progress  Int      @default(0)
  watchedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  episode   Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@unique([userId, contentId, episodeId])
}

model Subscription {
  id        String           @id @default(cuid())
  userId    String           @unique
  plan      SubscriptionPlan @default(FREE)
  expiresAt DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}
